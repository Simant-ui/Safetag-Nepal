# Copy to .env and fill in. Never commit .env.

PORT=4000
NODE_ENV=development

# MongoDB Atlas connection string (Database Access user + password, then Network Access IP allowlist).
# Rotate any credential that was ever pasted in chat/logs before using it here.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/safetag?appName=Cluster0

# Long random string — used to sign session JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# The web app's origin, for CORS.
WEB_APP_ORIGIN=http://localhost:3000

# Single hardcoded admin login for the admin panel. Change these before deploying anywhere real.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# Optional (Phase 3+) — leave blank to keep image upload in local-echo mode.
CLOUDINARY_URL=

# Optional (Phase 3+) — leave blank; Google login returns 501 until this is set up.
GOOGLE_OAUTH_CLIENT_ID=

# Optional (Phase 3+) — SMS OTP gateway (e.g. Sparrow SMS for Nepal). Leave blank to keep
# using the fixed dev OTP code (visible in non-production responses only).
SMS_GATEWAY_API_KEY=

# Optional (Phase 3+) — Twilio/Exotel call-masking credentials.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional (Phase 3+) — eSewa / Khalti / Fonepay payment gateway credentials.
ESEWA_MERCHANT_CODE=
KHALTI_SECRET_KEY=
