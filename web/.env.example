# Copy to .env.local and fill in when the backend phase begins.
# Not used while NEXT_PUBLIC_USE_MOCK_API=true (the default for this phase).

# Set to "false" once the real backend (server/) is deployed and reachable.
NEXT_PUBLIC_USE_MOCK_API=true

# Real backend base URL (Phase 2)
NEXT_PUBLIC_API_BASE_URL=https://api.safetag.np/v1

# Public QR base URL — should match this app's own deployed origin + /q, e.g. https://safetag.np/q
NEXT_PUBLIC_QR_BASE_URL=http://localhost:3000/q

# Google Sign-In (Phase 2+)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Firebase Web Push (Phase 2+)
NEXT_PUBLIC_FCM_VAPID_KEY=
