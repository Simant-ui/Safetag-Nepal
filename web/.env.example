# Copy to .env.local and fill in. Never commit .env.local.
# The backend now lives inside this app (src/app/api/**), so there's only one project to
# configure and one place to deploy (Vercel) — no separate server/ service needed.

NEXT_PUBLIC_USE_MOCK_API=false

# Public QR base URL — should match this app's own deployed origin + /q, e.g. https://safetag.np/q
NEXT_PUBLIC_QR_BASE_URL=http://localhost:3000/q

# Only set this if the API is ever split into a separate deployment again. Same-origin
# (the default, "/api") is correct as long as frontend and API routes live in this one app.
NEXT_PUBLIC_API_BASE_URL=

# --- Backend secrets (server-only — no NEXT_PUBLIC_ prefix, never sent to the browser) ---

# MongoDB Atlas connection string (Database Access user + password, then Network Access
# IP allowlist — for Vercel serverless functions, allow 0.0.0.0/0 since there's no fixed
# outbound IP on the standard plan). Rotate any credential ever pasted in chat/logs first.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/safetag?appName=Cluster0

# Long random string — used to sign session JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Single hardcoded admin login for the admin panel. Change these before deploying anywhere real.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# Optional (Phase 3+) — leave blank to keep image upload in local-echo mode.
CLOUDINARY_URL=

# Optional (Phase 3+) — leave blank; Google login returns 501 until this is set up.
GOOGLE_OAUTH_CLIENT_ID=

# Optional (Phase 3+) — SMS OTP gateway (e.g. Sparrow SMS for Nepal). Leave blank to keep
# using the last-4-digits-of-phone dev OTP code (visible in non-production responses only).
SMS_GATEWAY_API_KEY=

# Optional (Phase 3+) — Twilio/Exotel call-masking credentials.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional (Phase 3+) — eSewa / Khalti / Fonepay payment gateway credentials.
ESEWA_MERCHANT_CODE=
KHALTI_SECRET_KEY=
